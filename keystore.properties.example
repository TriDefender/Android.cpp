# Signing configuration
# 1. Copy this file: cp keystore.properties.example keystore.properties
# 2. Generate a keystore: ./generate-keystore.sh   (or generate-keystore.bat on Windows)
# 3. Fill in the values below

# Keystore file path (relative to project root)
storeFile=release.keystore

# Keystore password
storePassword=

# Key alias
keyAlias=release

# Key password (usually same as keystore password)
keyPassword=
